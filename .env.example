# PolyWeather Trading Bot Environment Configuration

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=polyweather
POSTGRES_USER=polyweather_user
POSTGRES_PASSWORD=secure_trading_pass_2024
DATABASE_URL=postgresql://polyweather_user:secure_trading_pass_2024@localhost:5433/polyweather

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380/0

# Trading Configuration
STARTING_CAPITAL=50.00
MAX_POSITION_SIZE=5.00
MIN_POSITION_SIZE=2.00
MAX_DAILY_TRADES=3
RISK_PER_TRADE=0.02
MIN_EDGE_THRESHOLD=0.02

# API Keys (to be filled in)
POLYMARKET_API_KEY=your_polymarket_api_key_here
OPENWEATHER_API_KEY=your_openweather_api_key_here
NOAA_API_KEY=your_noaa_api_key_here
POLYCLAW_PRIVATE_KEY=your_wallet_private_key_here

# Rate Limiting
WEATHER_API_RATE_LIMIT=1000
POLYMARKET_API_RATE_LIMIT=100

# WebSocket Configuration
WEBSOCKET_RECONNECT_DELAY=5.0
WEBSOCKET_MAX_RETRIES=10

# Monitoring
PROMETHEUS_PORT=8000
ENABLE_METRICS=true
LOG_LEVEL=INFO

# Performance Settings
CACHE_TTL_SECONDS=300
MAX_CONCURRENT_REQUESTS=10
DATABASE_POOL_SIZE=20
QUERY_TIMEOUT_SECONDS=30

# Development/Testing
DEVELOPMENT_MODE=false
PAPER_TRADING=true
BACKTEST_MODE=false